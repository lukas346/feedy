# Feedy - Environment Variables
# Copy this file to .env and modify as needed

# Application port (default: 8000)
APP_PORT=8000

# Database URL (default: sqlite:///data/reader.db)
# For SQLite, the path is relative to /app inside the container
DATABASE_URL=sqlite:///data/reader.db

# Worker interval in minutes (default: 15)
# How often the background worker checks for new articles
WORKER_INTERVAL_MINUTES=15

# Base URL for external links (bookmarklet, etc.)
# Set this if behind a reverse proxy or using a custom domain
# If not set, uses the request URL automatically
BASE_URL=https://feedy.example.com
